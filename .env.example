# Copy this file to .env and fill in your own values.
# All VITE_* vars are exposed to the client bundle — never put secret keys here.

# Supabase (publishable / anon — safe for the browser)
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Mapbox public token (pk.*) — safe to ship in the browser.
# Create one at https://account.mapbox.com/access-tokens/ and add URL
# restrictions so it only works from your own domains.
VITE_MAPBOX_TOKEN=
